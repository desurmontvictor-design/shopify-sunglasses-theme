<section class="nl-section">
  <div class="wrap--sm reveal">
    {% if section.settings.eyebrow != blank %}
      <span class="s-eyebrow" style="text-align:center;display:block;">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2 class="nl-title t-disp t-lg">{{ section.settings.title | default: 'ACCÈS PRIVÉ' }}</h2>
    {% if section.settings.sub != blank %}
      <p class="nl-sub">{{ section.settings.sub }}</p>
    {% endif %}
    {% form 'customer', id: 'nl-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="nl-form">
        <input class="nl-input" type="email" name="contact[email]"
          placeholder="{{ section.settings.placeholder | default: 'Votre adresse email' }}"
          required aria-label="Email">
        <button type="submit" class="nl-btn">{{ section.settings.btn | default: "S'INSCRIRE" }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p style="text-align:center;margin-top:1rem;font-family:var(--f-body);font-style:italic;font-size:.88rem;color:var(--muted);">
          Merci. Bienvenue dans le cercle Clairzal.
        </p>
      {% endif %}
    {% endform %}
    <p style="font-family:var(--f-body);font-style:italic;font-size:.72rem;color:var(--muted);margin-top:1rem;text-align:center;">
      Désinscription à tout moment. Aucun spam.
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Accroche",     "default": "Le cercle Clairzal"    },
    { "type": "text",     "id": "title",       "label": "Titre",        "default": "ACCÈS PRIVÉ"           },
    { "type": "textarea", "id": "sub",         "label": "Sous-titre",   "default": "Nouvelles collections, séries limitées, avant-premières. Réservé à nos abonnés." },
    { "type": "text",     "id": "placeholder", "label": "Placeholder",  "default": "Votre adresse email"   },
    { "type": "text",     "id": "btn",         "label": "Bouton",       "default": "S'INSCRIRE"            }
  ],
  "presets": [{ "name": "Newsletter", "category": "Email" }]
}
{% endschema %}
