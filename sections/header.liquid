<header class="site-header" id="site-header">
  <div class="wrap">
    <div class="header-grid">

      <nav class="header-nav" aria-label="Navigation">
        {% assign menu = linklists[section.settings.menu] %}
        {% if menu %}
          {% for link in menu.links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="/collections/all">Boutique</a>
          <a href="/pages/notre-histoire">Histoire</a>
        {% endif %}
      </nav>

      <a href="/" class="site-logo" aria-label="{{ shop.name }}">
        {{ section.settings.logo | default: shop.name }}
      </a>

      <div class="header-actions">
        <a href="/account" class="hbtn" aria-label="Compte">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="5.5" r="3.5"/>
            <path d="M1.5 17c0-4 3.4-6.5 7.5-6.5s7.5 2.5 7.5 6.5"/>
          </svg>
        </a>
        <button class="hbtn" id="cart-btn" aria-label="Panier">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M1 1h2.5l2.2 9h8.6l1.7-5.5H5.5"/>
            <circle cx="8" cy="15.5" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="15.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
          <span class="cart-dot" id="cart-dot">{{ cart.item_count }}</span>
        </button>
        <button class="burger hbtn" id="burger-btn" aria-label="Menu" aria-expanded="false">
          <span></span><span></span>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Fullscreen overlay nav -->
<nav class="overlay-nav" id="overlay-nav" aria-hidden="true">
  <button class="overlay-close hbtn" id="overlay-close" aria-label="Fermer">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <line x1="3" y1="3" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/>
      <line x1="21" y1="3" x2="3" y2="21" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </button>
  {% if menu %}
    {% for link in menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  {% else %}
    <a href="/collections/all">Boutique</a>
    <a href="/pages/notre-histoire">Histoire</a>
    <a href="/pages/contact">Contact</a>
  {% endif %}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text",      "id": "logo",  "label": "Logo (texte)", "default": "CLAIRZAL" },
    { "type": "link_list", "id": "menu",  "label": "Menu",         "default": "main-menu" }
  ]
}
{% endschema %}
