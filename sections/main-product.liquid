{% assign cv = product.selected_or_first_available_variant %}

<div class="pdp" id="pdp-{{ product.id }}">

  <!-- Galerie -->
  <div class="pdp__gallery">
    <div class="pdp__main-img" id="pdp-main">
      <img
        id="pdp-img"
        src="{{ product.featured_image | img_url: '1000x' }}"
        srcset="{{ product.featured_image | img_url: '700x' }} 700w, {{ product.featured_image | img_url: '1000x' }} 1000w"
        alt="{{ product.title | escape }}"
        loading="eager"
      >
    </div>
    {% if product.images.size > 1 %}
      <div class="pdp__thumbs">
        {% for img in product.images limit: 6 %}
          <div class="pdp__thumb {% if forloop.first %}on{% endif %}" data-src="{{ img | img_url: '1000x' }}" tabindex="0">
            <img src="{{ img | img_url: '200x' }}" alt="{{ img.alt | escape }}">
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Infos -->
  <div class="pdp__info">

    <!-- Évaluations -->
    <div class="pdp__rating">
      <span style="color:#f59e0b;letter-spacing:.1em;">★★★★★</span>
      <span style="font-size:.85rem;color:var(--gray);">4,9 · {{ section.settings.review_count | default: '127 avis' }}</span>
    </div>

    <h1 class="pdp__name">{{ product.title }}</h1>

    <div class="pdp__price" id="pdp-price">
      {% if cv.compare_at_price > cv.price %}
        <s style="opacity:.4;margin-right:.5rem;">{{ cv.compare_at_price | money }}</s>
      {% endif %}
      {{ cv.price | money }}
      {% if cv.compare_at_price > cv.price %}
        <span class="pdp__badge-sale">-{{ cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price }}%</span>
      {% endif %}
    </div>

    <!-- Bénéfices (before specs) -->
    <ul class="pdp__benefits">
      <li>✓ {{ section.settings.benefit_1 | default: 'Style immédiat — tu passes de banal à stylé' }}</li>
      <li>✓ {{ section.settings.benefit_2 | default: 'Verres polarisés UV400 — protection maximale' }}</li>
      <li>✓ {{ section.settings.benefit_3 | default: 'Monture légère — confort toute la journée' }}</li>
      <li>✓ {{ section.settings.benefit_4 | default: 'Étui rigide + chiffon microfibre inclus' }}</li>
    </ul>

    <hr class="pdp__divider">

    <form id="pdp-form" method="post" action="/cart/add">
      <input type="hidden" name="id" id="pdp-variant" value="{{ cv.id }}">

      {% unless product.has_only_default_variant %}
        {% for opt in product.options_with_values %}
          <div style="margin-bottom:1.5rem;">
            <span class="pdp__label">{{ opt.name }}</span>
            {% if opt.name == 'Couleur' or opt.name == 'Color' %}
              <div class="swatches" data-opt="{{ forloop.index0 }}">
                {% for v in opt.values %}
                  <div class="swatch {% if forloop.first %}on{% endif %}"
                    data-val="{{ v }}"
                    style="background:{{ v | downcase | replace: ' ', '' }};"
                    title="{{ v }}" tabindex="0" role="button"></div>
                {% endfor %}
              </div>
            {% else %}
              <div class="vpills" data-opt="{{ forloop.index0 }}">
                {% for v in opt.values %}
                  <button type="button" class="vpill {% if forloop.first %}on{% endif %}" data-val="{{ v }}">{{ v }}</button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% endunless %}

      <div class="pdp__ctas">
        <button type="submit" class="btn btn-black btn-full btn-xl" id="pdp-atc" {% unless cv.available %}disabled{% endunless %}>
          {% if cv.available %}Ajouter au panier{% else %}Épuisé{% endif %}
        </button>
        {% if section.settings.show_buy_now %}
          <a href="/checkout?variant={{ cv.id }}" class="btn btn-outline btn-full" id="pdp-buynow" style="margin-top:.75rem;">
            Acheter maintenant
          </a>
        {% endif %}
      </div>

    </form>

    <!-- Réassurance rapide -->
    <div class="pdp__reassurance">
      <span>🚚 Livraison offerte</span>
      <span>↩️ Retours 30j</span>
      <span>🔒 Paiement sécurisé</span>
    </div>

    <!-- Accordion -->
    <div class="acc">
      {% if product.description != blank %}
        <div class="acc__item">
          <button class="acc__hd" type="button">Description <span class="acc__ico"></span></button>
          <div class="acc__bd"><div class="acc__content">{{ product.description }}</div></div>
        </div>
      {% endif %}
      <div class="acc__item">
        <button class="acc__hd" type="button">Caractéristiques <span class="acc__ico"></span></button>
        <div class="acc__bd">
          <div class="acc__content">{{ section.settings.specs | default: 'Monture acétate · Verres polarisés UV400 · Catégorie 3 · Fabriqué en Italie · Étui rigide + chiffon microfibre inclus' }}</div>
        </div>
      </div>
      <div class="acc__item">
        <button class="acc__hd" type="button">Livraison & retours <span class="acc__ico"></span></button>
        <div class="acc__bd">
          <div class="acc__content">{{ section.settings.delivery | default: 'Livraison offerte en France métropolitaine. Expédition sous 24–48h (jours ouvrés). Retours gratuits sous 30 jours.' }}</div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Sticky ATC bar (mobile) -->
<div class="sticky-bar" id="sticky-bar">
  <div class="sticky-bar__info">
    <span class="sticky-bar__name">{{ product.title }}</span>
    <span class="sticky-bar__price" id="sticky-price">{{ cv.price | money }}</span>
  </div>
  <button class="btn btn-black" id="sticky-atc" {% unless cv.available %}disabled{% endunless %}>
    {% if cv.available %}Ajouter{% else %}Épuisé{% endif %}
  </button>
</div>

<script type="application/json" id="variants-json">{{ product.variants | json }}</script>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    { "type": "checkbox",  "id": "show_buy_now",  "label": "Bouton acheter maintenant", "default": true },
    { "type": "text",      "id": "review_count",  "label": "Nombre d'avis",             "default": "127 avis" },
    { "type": "text",      "id": "benefit_1",     "label": "Bénéfice 1",                "default": "Style immédiat — tu passes de banal à stylé" },
    { "type": "text",      "id": "benefit_2",     "label": "Bénéfice 2",                "default": "Verres polarisés UV400 — protection maximale" },
    { "type": "text",      "id": "benefit_3",     "label": "Bénéfice 3",                "default": "Monture légère — confort toute la journée" },
    { "type": "text",      "id": "benefit_4",     "label": "Bénéfice 4",                "default": "Étui rigide + chiffon microfibre inclus" },
    { "type": "textarea",  "id": "specs",         "label": "Caractéristiques" },
    { "type": "textarea",  "id": "delivery",      "label": "Livraison & retours" }
  ]
}
{% endschema %}
