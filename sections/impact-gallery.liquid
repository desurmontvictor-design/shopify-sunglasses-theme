<section class="impact reveal">
  <div class="wrap">
    <div class="impact__text">
      <h2 class="t-h2">{{ section.settings.title | default: 'Un détail qui change tout.' }}</h2>
      <p class="t-body" style="color:var(--gray);max-width:480px;margin:.75rem auto 0;">{{ section.settings.sub | default: 'Fabriquées pour ceux qui savent que le style, ça se voit de loin.' }}</p>
    </div>
    <div class="impact__grid">
      {% for i in (1..3) %}
        {% assign img_id = 'image_' | append: i %}
        {% assign cap_id = 'caption_' | append: i %}
        <div class="impact__item">
          {% if section.settings[img_id] != blank %}
            <img
              src="{{ section.settings[img_id] | img_url: '700x' }}"
              alt="{{ section.settings[cap_id] | default: 'Clairzal' | escape }}"
              loading="lazy"
            >
          {% else %}
            <div class="impact__placeholder"></div>
          {% endif %}
          {% if section.settings[cap_id] != blank %}
            <p class="impact__cap">{{ section.settings[cap_id] }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Impact Gallery",
  "settings": [
    { "type": "text",         "id": "title",     "label": "Titre",       "default": "Un détail qui change tout." },
    { "type": "text",         "id": "sub",       "label": "Sous-titre",  "default": "Fabriquées pour ceux qui savent que le style, ça se voit de loin." },
    { "type": "image_picker", "id": "image_1",   "label": "Image 1" },
    { "type": "text",         "id": "caption_1", "label": "Légende 1",   "default": "Monture acétate italien" },
    { "type": "image_picker", "id": "image_2",   "label": "Image 2" },
    { "type": "text",         "id": "caption_2", "label": "Légende 2",   "default": "Verres polarisés UV400" },
    { "type": "image_picker", "id": "image_3",   "label": "Image 3" },
    { "type": "text",         "id": "caption_3", "label": "Légende 3",   "default": "Fabriquées en Italie" }
  ],
  "presets": [{ "name": "Impact Gallery", "category": "Image" }]
}
{% endschema %}
