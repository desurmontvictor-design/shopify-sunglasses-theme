<div class="cart-pg">
  <div class="wrap">
    <h1 class="cart-pg__h">VOTRE SÉLECTION</h1>

    {% if cart.item_count > 0 %}
      <div class="cart-layout">

        <!-- Items -->
        <div>
          {% for item in cart.items %}
            <div class="cart-item" id="ci-{{ item.key }}">
              <a href="{{ item.url }}">
                <img class="cart-item__img" src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}">
              </a>
              <div>
                <div class="cart-item__name">{{ item.product.title | upcase }}</div>
                {% unless item.variant.title == 'Default Title' %}
                  <div class="cart-item__var">{{ item.variant.title }}</div>
                {% endunless %}
                <div class="qty" style="margin-top:.75rem;">
                  <button type="button" class="qty-m" data-key="{{ item.key }}">−</button>
                  <input type="number" value="{{ item.quantity }}" min="0" data-key="{{ item.key }}" aria-label="Quantité">
                  <button type="button" class="qty-p" data-key="{{ item.key }}">+</button>
                </div>
                <button class="cart-item__rm" data-key="{{ item.key }}">RETIRER</button>
              </div>
              <div class="cart-item__p">{{ item.final_line_price | money }}</div>
            </div>
          {% endfor %}
        </div>

        <!-- Résumé -->
        <div class="cart-sum">
          <div class="cart-sum__h">RÉCAPITULATIF</div>
          <div class="cart-sum__row"><span>Sous-total</span><span>{{ cart.total_price | money }}</span></div>
          {% if cart.total_discount > 0 %}
            <div class="cart-sum__row"><span>Remise</span><span>−{{ cart.total_discount | money }}</span></div>
          {% endif %}
          <div class="cart-sum__row"><span>Livraison</span><span>Offerte</span></div>
          <div class="cart-sum__total"><span>TOTAL</span><span>{{ cart.total_price | money }}</span></div>
          <a href="/checkout" class="btn btn-navy btn-full">COMMANDER</a>
          <a href="/collections/all" class="btn btn-line btn-full" style="margin-top:.5rem;">CONTINUER</a>
          <p class="cart-sum__note">Livraison offerte en France</p>
        </div>

      </div>
    {% else %}
      <div style="text-align:center;padding:7rem 0;">
        <p style="font-family:var(--f-body);font-style:italic;font-size:1.1rem;color:var(--muted);margin-bottom:2.5rem;">Votre panier est vide.</p>
        <a href="/collections/all" class="btn btn-navy">DÉCOUVRIR LA COLLECTION</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{ "name": "Cart" }
{% endschema %}
