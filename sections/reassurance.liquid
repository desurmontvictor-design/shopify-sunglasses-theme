<div class="assurance">
  {% for block in section.blocks %}
    <div class="assurance__item" {{ block.shopify_attributes }}>
      <span class="assurance__label t-label">{{ block.settings.title | upcase }}</span>
      <span class="assurance__desc">{{ block.settings.desc }}</span>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Réassurance",
  "max_blocks": 3,
  "blocks": [{
    "type": "item", "name": "Élément",
    "settings": [
      { "type": "text", "id": "title", "label": "Titre", "default": "LIVRAISON OFFERTE" },
      { "type": "text", "id": "desc",  "label": "Description", "default": "En France, sans minimum." }
    ]
  }],
  "presets": [{
    "name": "Réassurance", "category": "Text",
    "blocks": [
      { "type": "item", "settings": { "title": "LIVRAISON OFFERTE", "desc": "En France métropolitaine, sans minimum d'achat." } },
      { "type": "item", "settings": { "title": "SÉRIE LIMITÉE",     "desc": "Chaque modèle est édité en quantités restreintes." } },
      { "type": "item", "settings": { "title": "RETOURS 30 JOURS",  "desc": "Pas convaincu·e ? On reprend, sans question." } }
    ]
  }]
}
{% endschema %}
