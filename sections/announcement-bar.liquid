{% if section.settings.show %}
<div class="announce">
  {{ section.settings.text }}
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Afficher la barre", "default": true },
    { "type": "text",     "id": "text", "label": "Texte",             "default": "🚚 Livraison offerte en France · 2 paires = 1 offerte" }
  ]
}
{% endschema %}
