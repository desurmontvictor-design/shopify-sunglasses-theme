<section class="split {% if section.settings.reverse %}split--rev{% endif %}">

  <div class="split__img">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | img_url: '1000x' }}"
        srcset="{{ section.settings.image | img_url: '700x' }} 700w, {{ section.settings.image | img_url: '1000x' }} 1000w"
        sizes="50vw"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        style="transition:transform 1.2s var(--ease-out);"
      >
    {% else %}
      <div style="width:100%;height:100%;background:var(--navy-d);"></div>
    {% endif %}
  </div>

  <div class="split__txt">
    <div class="reveal">
      {% if section.settings.tag != blank %}
        <span class="split__tag t-label" style="font-family:var(--f-disp);font-size:.6rem;letter-spacing:.22em;display:block;margin-bottom:1.5rem;">{{ section.settings.tag | upcase }}</span>
      {% endif %}
      <h2 class="split__title">{{ section.settings.title | default: 'NÉES POUR ÊTRE PORTÉES' | newline_to_br }}</h2>
      {% if section.settings.body != blank %}
        <p class="split__body">{{ section.settings.body }}</p>
      {% endif %}
      {% if section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="link-arrow" style="color:rgba(245,243,238,.35);">
          {{ section.settings.link_label | default: "DÉCOUVRIR L'HISTOIRE" }}
        </a>
      {% endif %}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Notre Histoire",
  "settings": [
    { "type": "image_picker", "id": "image",      "label": "Visuel" },
    { "type": "text",         "id": "tag",         "label": "Tag",           "default": "NOTRE HISTOIRE" },
    { "type": "textarea",     "id": "title",       "label": "Titre",         "default": "NÉES POUR\nÊTRE PORTÉES" },
    { "type": "textarea",     "id": "body",        "label": "Corps (italic)","default": "Clairzal est née d'une obsession : créer des lunettes qui disparaissent au visage pour ne laisser voir que vous." },
    { "type": "url",          "id": "link_url",    "label": "Lien" },
    { "type": "text",         "id": "link_label",  "label": "Texte lien",    "default": "DÉCOUVRIR L'HISTOIRE" },
    { "type": "checkbox",     "id": "reverse",     "label": "Image à droite","default": false }
  ],
  "presets": [{ "name": "Notre Histoire", "category": "Image" }]
}
{% endschema %}
