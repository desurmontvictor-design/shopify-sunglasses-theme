<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">

      <div>
        <a href="/" class="footer-logo">{{ section.settings.logo | default: shop.name | upcase }}</a>
        <p class="footer-tagline">{{ section.settings.tagline | default: "L'élégance a trouvé son regard." }}</p>
        <div class="footer-social">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok != blank %}
            <a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">TK</a>
          {% endif %}
        </div>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">BOUTIQUE</span>
        <ul>
          <li><a href="/collections/all">Toutes les lunettes</a></li>
          <li><a href="/collections/nouveautes">Nouveautés</a></li>
          <li><a href="/collections/homme">Homme</a></li>
          <li><a href="/collections/femme">Femme</a></li>
          <li><a href="/collections/editions-limitees">Éditions limitées</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">CLAIRZAL</span>
        <ul>
          <li><a href="/pages/notre-histoire">Notre histoire</a></li>
          <li><a href="/pages/artisanat">Artisanat</a></li>
          <li><a href="/blogs/journal">Journal</a></li>
          <li><a href="/pages/presse">Presse</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">AIDE</span>
        <ul>
          <li><a href="/pages/livraison">Livraison & retours</a></li>
          <li><a href="/pages/guide-tailles">Guide des tailles</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      <div class="footer-links">
        <a href="/policies/privacy-policy">Confidentialité</a>
        <a href="/policies/terms-of-service">CGV</a>
        <a href="/policies/refund-policy">Remboursements</a>
      </div>
      <span style="opacity:.4;">Fait avec soin, en France.</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text",     "id": "logo",      "label": "Logo",     "default": "CLAIRZAL" },
    { "type": "textarea", "id": "tagline",   "label": "Tagline",  "default": "L'élégance a trouvé son regard." },
    { "type": "url",      "id": "instagram", "label": "Instagram" },
    { "type": "url",      "id": "tiktok",    "label": "TikTok"    }
  ]
}
{% endschema %}
