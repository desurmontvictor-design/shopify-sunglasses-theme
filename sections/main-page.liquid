<div style="padding:6rem 0;min-height:60vh;">
  <div class="container--narrow">
    <h1 style="font-family:var(--font-display);font-size:clamp(2.5rem,5vw,4rem);color:var(--color-primary);margin-bottom:0.5rem;letter-spacing:0.02em;">
      {{ page.title | upcase }}
    </h1>
    <hr style="border:none;border-top:0.5px solid var(--color-border);margin:2rem 0;">
    <div style="font-family:var(--font-body);font-style:italic;font-size:1rem;font-weight:300;color:var(--color-text-muted);line-height:1.9;">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page"
}
{% endschema %}
