<section class="statement">
  <div class="statement__wm" aria-hidden="true">{{ section.settings.wm | default: 'CLAIRZAL' | upcase }}</div>
  <div class="statement__body reveal">
    {% if section.settings.eyebrow != blank %}
      <span class="s-eyebrow" style="color:rgba(245,243,238,.3);margin-bottom:2rem;">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2 class="statement__title">{{ section.settings.title | default: "L'ÉLÉGANCE A TROUVÉ SON REGARD" | newline_to_br }}</h2>
    {% if section.settings.sub != blank %}
      <p class="statement__sub">{{ section.settings.sub }}</p>
    {% endif %}
    {% if section.settings.cta_url != blank %}
      <a href="{{ section.settings.cta_url }}" class="btn btn-line-w">{{ section.settings.cta | default: 'EXPLORER' }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Statement",
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Accroche" },
    { "type": "textarea", "id": "title",   "label": "Titre",          "default": "L'ÉLÉGANCE\nA TROUVÉ\nSON REGARD" },
    { "type": "textarea", "id": "sub",     "label": "Sous-titre",     "default": "Chaque paire raconte une histoire. La vôtre commence ici." },
    { "type": "text",     "id": "wm",      "label": "Watermark texte","default": "CLAIRZAL" },
    { "type": "url",      "id": "cta_url", "label": "Lien CTA" },
    { "type": "text",     "id": "cta",     "label": "Texte CTA",      "default": "EXPLORER" }
  ],
  "presets": [{ "name": "Statement", "category": "Text" }]
}
{% endschema %}
