<section class="hero">

  <div class="hero__bg">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | img_url: '2000x' }}"
        srcset="{{ section.settings.image | img_url: '800x'  }} 800w,
                {{ section.settings.image | img_url: '1400x' }} 1400w,
                {{ section.settings.image | img_url: '2000x' }} 2000w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: shop.name | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      <div style="width:100%;height:100%;background:#0a0a0a;"></div>
    {% endif %}
  </div>

  <div class="hero__veil"></div>

  <div class="hero__content">
    <p class="hero__kicker">{{ section.settings.kicker | default: 'Lunettes de soleil' }}</p>
    <h1 class="hero__title">{{ section.settings.title | default: "L'élégance,\ninstantanément." | newline_to_br }}</h1>
    <p class="hero__sub">{{ section.settings.sub | default: 'Tu passes de banal à stylé en 3 secondes.' }}</p>
    <div class="hero__ctas">
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn-white btn-xl">
        {{ section.settings.cta | default: 'Voir les modèles' }}
      </a>
      {% if section.settings.cta2_url != blank %}
        <a href="{{ section.settings.cta2_url }}" class="btn btn-outline-white">
          {{ section.settings.cta2 | default: 'Notre histoire' }}
        </a>
      {% endif %}
    </div>
    <div class="hero__trust">
      <span>⭐⭐⭐⭐⭐</span>
      <span>{{ section.settings.trust | default: '+2 000 paires vendues · Livraison offerte' }}</span>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="11" stroke="rgba(255,255,255,.3)" stroke-width="1"/>
      <path d="M12 8v8M9 13l3 3 3-3" stroke="white" stroke-width="1.2"/>
    </svg>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image",    "label": "Image de fond" },
    { "type": "text",         "id": "kicker",   "label": "Accroche (petite)",     "default": "Lunettes de soleil" },
    { "type": "textarea",     "id": "title",    "label": "Titre principal",        "default": "L'élégance,\ninstantanément." },
    { "type": "text",         "id": "sub",      "label": "Sous-titre",             "default": "Tu passes de banal à stylé en 3 secondes." },
    { "type": "url",          "id": "cta_url",  "label": "Lien bouton principal" },
    { "type": "text",         "id": "cta",      "label": "Texte bouton principal", "default": "Voir les modèles" },
    { "type": "url",          "id": "cta2_url", "label": "Lien bouton secondaire" },
    { "type": "text",         "id": "cta2",     "label": "Texte bouton secondaire","default": "Notre histoire" },
    { "type": "text",         "id": "trust",    "label": "Ligne de confiance",     "default": "+2 000 paires vendues · Livraison offerte" }
  ],
  "presets": [{ "name": "Hero", "category": "Image" }]
}
{% endschema %}
