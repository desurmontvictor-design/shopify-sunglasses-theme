{% assign col = collections[section.settings.collection] %}

<section class="products-section" id="products">
  <div class="wrap">

    <div class="products-section__hd reveal">
      <h2 class="t-h2">{{ section.settings.title | default: 'Nos modèles' }}</h2>
      <p class="t-body" style="color:var(--gray);margin-top:.5rem;">{{ section.settings.sub | default: 'Chaque paire pensée pour durer, conçue pour impressionner.' }}</p>
    </div>

    <div class="pcards-grid">
      {% for product in col.products limit: section.settings.limit %}
        <a href="{{ product.url }}" class="pcard reveal">
          <div class="pcard__fig">
            {% if product.featured_image %}
              <img class="pcard__img"
                src="{{ product.featured_image | img_url: '600x' }}"
                srcset="{{ product.featured_image | img_url: '400x' }} 400w, {{ product.featured_image | img_url: '600x' }} 600w"
                sizes="(max-width:768px) 50vw, 33vw"
                alt="{{ product.title | escape }}" loading="lazy">
            {% else %}
              <div style="width:100%;height:100%;background:var(--light);"></div>
            {% endif %}
            {% if product.tags contains 'bestseller' %}<span class="pcard__badge">Bestseller</span>{% endif %}
            {% if product.tags contains 'nouveau' %}<span class="pcard__badge">Nouveau</span>{% endif %}
            <div class="pcard__over">
              <span class="pcard__add" data-id="{{ product.variants.first.id }}">Ajouter au panier</span>
            </div>
          </div>
          <div class="pcard__meta">
            <span class="pcard__name">{{ product.title }}</span>
            <span class="pcard__price">
              {% if product.compare_at_price > product.price %}
                <s style="opacity:.4;margin-right:.3rem;">{{ product.compare_at_price | money }}</s>
              {% endif %}
              {{ product.price | money }}
            </span>
          </div>
        </a>
      {% else %}
        <p style="grid-column:1/-1;text-align:center;color:var(--gray);padding:4rem 0;">Sélectionnez une collection dans les paramètres.</p>
      {% endfor %}
    </div>

    {% if col != blank %}
      <div style="text-align:center;margin-top:3rem;">
        <a href="{{ col.url }}" class="btn btn-outline">Voir toute la collection</a>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Produits phares",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "text",       "id": "title",      "label": "Titre",            "default": "Nos modèles" },
    { "type": "text",       "id": "sub",        "label": "Sous-titre",       "default": "Chaque paire pensée pour durer, conçue pour impressionner." },
    { "type": "range",      "id": "limit",      "label": "Nb de produits",   "min": 3, "max": 6, "step": 3, "default": 6 }
  ],
  "presets": [{ "name": "Produits phares", "category": "Collection" }]
}
{% endschema %}
