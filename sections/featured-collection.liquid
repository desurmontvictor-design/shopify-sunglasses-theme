{% assign col = collections[section.settings.collection] %}

<section style="padding: clamp(5rem,10vw,10rem) 0;">
  <div class="wrap">

    <div class="s-head reveal">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="s-eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        <h2 class="t-disp t-lg">{{ section.settings.title | default: 'LA COLLECTION' }}</h2>
      </div>
      {% if col != blank %}
        <a href="{{ col.url }}" class="link-arrow">TOUT VOIR</a>
      {% endif %}
    </div>

    <!-- Editorial grid : 1 grande + 3 petites -->
    <div class="ed-grid">

      <!-- Grande carte -->
      {% assign big = col.products | first %}
      {% if big %}
        <a href="{{ big.url }}" class="pcard pcard--big reveal">
          <div class="pcard__fig">
            {% if big.featured_image %}
              <img class="pcard__img"
                src="{{ big.featured_image | img_url: '900x' }}"
                srcset="{{ big.featured_image | img_url: '600x' }} 600w, {{ big.featured_image | img_url: '900x' }} 900w"
                sizes="(max-width:768px) 100vw, 55vw"
                alt="{{ big.title | escape }}" loading="lazy">
            {% endif %}
            {% if big.tags contains 'bestseller' %}
              <span class="pcard__badge">BESTSELLER</span>
            {% elsif big.tags contains 'nouveau' %}
              <span class="pcard__badge">NOUVEAU</span>
            {% endif %}
            <div class="pcard__over">
              <span class="pcard__add" data-id="{{ big.variants.first.id }}">AJOUTER AU PANIER</span>
            </div>
          </div>
          <div class="pcard__meta">
            <span class="pcard__name">{{ big.title | upcase }}</span>
            <span class="pcard__price">{{ big.price | money }}</span>
          </div>
        </a>
      {% else %}
        <div class="pcard pcard--big" style="background:var(--warm);">
          <div class="pcard__fig" style="display:flex;align-items:center;justify-content:center;">
            <span style="font-family:var(--f-body);font-style:italic;font-size:.85rem;color:var(--muted);">Sélectionnez une collection</span>
          </div>
        </div>
      {% endif %}

      <!-- 3 petites cartes -->
      <div class="ed-grid__small">
        {% for product in col.products offset: 1 limit: 3 %}
          <a href="{{ product.url }}" class="pcard pcard--small reveal reveal-delay-{{ forloop.index }}">
            <div class="pcard__fig">
              {% if product.featured_image %}
                <img class="pcard__img"
                  src="{{ product.featured_image | img_url: '500x' }}"
                  alt="{{ product.title | escape }}" loading="lazy">
              {% endif %}
              {% if product.tags contains 'bestseller' %}
                <span class="pcard__badge">BESTSELLER</span>
              {% elsif product.tags contains 'nouveau' %}
                <span class="pcard__badge">NOUVEAU</span>
              {% endif %}
              <div class="pcard__over">
                <span class="pcard__add" data-id="{{ product.variants.first.id }}">AJOUTER</span>
              </div>
            </div>
            <div class="pcard__meta">
              <span class="pcard__name">{{ product.title | upcase }}</span>
              <span class="pcard__price">{{ product.price | money }}</span>
            </div>
          </a>
        {% else %}
          {% for i in (1..3) %}
            <div class="pcard pcard--small" style="background:var(--warm);"></div>
          {% endfor %}
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection"          },
    { "type": "text",       "id": "eyebrow",    "label": "Accroche",  "default": "Nos créations" },
    { "type": "text",       "id": "title",      "label": "Titre",     "default": "LA COLLECTION"  }
  ],
  "presets": [{ "name": "Featured Collection", "category": "Collection" }]
}
{% endschema %}
