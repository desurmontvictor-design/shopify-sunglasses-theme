<div class="marquee-strip" aria-hidden="true">
  <div class="marquee-track">
    {% assign items = section.settings.text | split: '—' %}
    {% for item in items %}
      <span>{{ item | strip | upcase }}</span>
      <span class="sep">—</span>
    {% endfor %}
    {% comment %}Duplicate for seamless loop{% endcomment %}
    {% for item in items %}
      <span>{{ item | strip | upcase }}</span>
      <span class="sep">—</span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte (séparer par —)",
      "default": "NOUVELLE COLLECTION — LIVRAISON OFFERTE — SÉRIE LIMITÉE — CLAIRZAL.COM — L'ÉLÉGANCE A TROUVÉ SON REGARD"
    }
  ],
  "presets": [
    { "name": "Marquee", "category": "Text" }
  ]
}
{% endschema %}
