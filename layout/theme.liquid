<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-bg: {{ settings.color_bg }};
      --color-secondary: {{ settings.color_secondary }};
      --color-primary-dark: #000e24;
    }
  </style>
</head>

<body class="template-{{ template.name }}">

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Cart Drawer -->
  <div id="cart-drawer" class="cart-drawer" aria-hidden="true" role="dialog" aria-label="Panier">
    <div class="cart-drawer__overlay" id="cart-overlay"></div>
    <div class="cart-drawer__panel">
      <div class="cart-drawer__head">
        <span class="cart-drawer__title">VOTRE SÉLECTION</span>
        <button class="cart-drawer__close" id="cart-close" aria-label="Fermer">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="1" y1="1" x2="17" y2="17" stroke="currentColor" stroke-width="1.2"/>
            <line x1="17" y1="1" x2="1" y2="17" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </button>
      </div>
      <div class="cart-drawer__body" id="cart-drawer-body">
        <p class="cart-drawer__empty">Votre panier est vide.</p>
      </div>
      <div class="cart-drawer__foot" id="cart-drawer-foot" style="display:none;">
        <div class="cart-drawer__subtotal">
          <span>SOUS-TOTAL</span>
          <span id="drawer-subtotal"></span>
        </div>
        <p class="cart-drawer__shipping">Livraison offerte en France métropolitaine</p>
        <a href="/checkout" class="btn btn--primary btn--full">COMMANDER</a>
        <a href="/cart" class="btn btn--ghost btn--full" style="margin-top:0.5rem;">VOIR LE PANIER</a>
      </div>
    </div>
  </div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
